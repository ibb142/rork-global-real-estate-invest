{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["backend/**/*.ts", "server.ts", "expo/shared/**/*.ts", "expo/constants/**/*.ts", "expo/lib/ivx-owner-variables-server.ts"],
  "exclude": ["node_modules", "dist"]
}
