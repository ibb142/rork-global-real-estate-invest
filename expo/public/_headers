# Prevent stale HTML/JS bundles from being cached on Cloudflare/Render edge.
# Hashed JS/CSS assets can still be cached long-term because their URLs change on every build.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  Vary: Accept-Encoding

/
  Cache-Control: public, max-age=0, must-revalidate
  Vary: Accept-Encoding
