############################################################
# IVX Holdings — Self-Hosted Supabase Environment Variables
# Copy to .env.supabase and fill in real values
# Generate keys with: node deploy/supabase/generate-keys.mjs
############################################################

# ─── POSTGRES ─────────────────────────────────────────────
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_32_CHARS
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ─── JWT ──────────────────────────────────────────────────
# Must be identical across ALL services. Min 32 chars.
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_JWT_SECRET
JWT_EXP=3600

# ─── API KEYS ────────────────────────────────────────────
# Generated by generate-keys.mjs using the JWT_SECRET above
ANON_KEY=REPLACE_WITH_GENERATED_ANON_KEY
SERVICE_ROLE_KEY=REPLACE_WITH_GENERATED_SERVICE_ROLE_KEY

# ─── URLs ─────────────────────────────────────────────────
# External URL where Kong is reachable (your domain or IP)
API_EXTERNAL_URL=https://db.ivxholding.com
# Your app's URL (for auth redirects)
SITE_URL=https://ivxholding.com
ADDITIONAL_REDIRECT_URLS=https://app.ivxholding.com,exp://localhost:8081

# ─── PORTS (change if conflicts) ─────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
STUDIO_PORT=3100
AUTH_PORT=9999
REST_PORT=3200
REALTIME_PORT=4000
STORAGE_PORT=5000
META_PORT=8080
FUNCTIONS_PORT=9000

# ─── SMTP (for auth emails) ──────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=REPLACE_WITH_SENDGRID_API_KEY
SMTP_ADMIN_EMAIL=noreply@ivxholding.com
SMTP_SENDER_NAME=IVX Holdings

# ─── EMAIL CONFIG ────────────────────────────────────────
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
DISABLE_SIGNUP=false
ENABLE_ANONYMOUS_SIGN_INS=false
RATE_LIMIT_EMAIL_SENT=100

# ─── SECURITY ────────────────────────────────────────────
SECRET_KEY_BASE=REPLACE_WITH_OPENSSL_RAND_HEX_64

# ─── AWS (for S3 storage backend, optional) ──────────────
AWS_REGION=us-east-1
