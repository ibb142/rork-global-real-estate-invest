# ============================================================
# IVX HOLDINGS — Production Environment Variables
# Copy to .env.production and fill in real values
# Used by: docker-compose.prod.yml, ECS task definition
# ============================================================

# ---- SYSTEM ----
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
ALLOWED_ORIGINS=https://ivxholding.com,https://www.ivxholding.com,https://app.ivxholding.com

# ---- AUTH (REQUIRED) ----
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ---- AWS (REQUIRED for S3/DynamoDB) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=ivx-holdings-prod

# ---- STRIPE (REQUIRED for live payments) ----
STRIPE_SECRET_KEY=sk_live_
STRIPE_PUBLISHABLE_KEY=pk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# ---- PLAID (REQUIRED for bank transfers) ----
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production

# ---- PAYPAL (optional) ----
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=production

# ---- APPLE PAY / GOOGLE PAY ----
APPLE_PAY_MERCHANT_ID=
GOOGLE_PAY_MERCHANT_ID=

# ---- TWILIO (REQUIRED for SMS/2FA) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ---- EMAIL (REQUIRED — choose one) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ivxholding.com
CEO_EMAIL=ceo@ivxholding.com

# ---- KYC (REQUIRED for identity verification) ----
ONFIDO_API_KEY=

# ---- MONITORING ----
SENTRY_DSN=

# ---- STORAGE ----
STORAGE_PROVIDER=s3
