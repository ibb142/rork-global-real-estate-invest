{
  "Comment": "IVX Holdings CDN Distribution",
  "Origins": {
    "Items": [
      {
        "Id": "S3-ivx-holdings-prod",
        "DomainName": "ivx-holdings-prod.s3.us-east-1.amazonaws.com",
        "S3OriginConfig": {
          "OriginAccessIdentity": "origin-access-identity/cloudfront/${CLOUDFRONT_OAI_ID}"
        }
      }
    ],
    "Quantity": 1
  },
  "DefaultCacheBehavior": {
    "TargetOriginId": "S3-ivx-holdings-prod",
    "ViewerProtocolPolicy": "redirect-to-https",
    "AllowedMethods": ["GET", "HEAD", "OPTIONS"],
    "CachedMethods": ["GET", "HEAD"],
    "Compress": true,
    "CachePolicyId": "658327ea-f89d-4fab-a63d-7e88639e58f6",
    "ResponseHeadersPolicyId": "eaab4381-ed33-4a86-88ca-d9558dc6cd63",
    "ForwardedValues": {
      "QueryString": false,
      "Cookies": { "Forward": "none" },
      "Headers": { "Quantity": 0 }
    },
    "MinTTL": 0,
    "DefaultTTL": 86400,
    "MaxTTL": 31536000
  },
  "CacheBehaviors": {
    "Items": [
      {
        "PathPattern": "/images/*",
        "TargetOriginId": "S3-ivx-holdings-prod",
        "ViewerProtocolPolicy": "redirect-to-https",
        "AllowedMethods": ["GET", "HEAD"],
        "Compress": true,
        "ForwardedValues": {
          "QueryString": false,
          "Cookies": { "Forward": "none" }
        },
        "MinTTL": 86400,
        "DefaultTTL": 604800,
        "MaxTTL": 31536000
      },
      {
        "PathPattern": "/documents/*",
        "TargetOriginId": "S3-ivx-holdings-prod",
        "ViewerProtocolPolicy": "redirect-to-https",
        "AllowedMethods": ["GET", "HEAD"],
        "Compress": true,
        "ForwardedValues": {
          "QueryString": true,
          "Cookies": { "Forward": "none" }
        },
        "MinTTL": 0,
        "DefaultTTL": 3600,
        "MaxTTL": 86400
      }
    ],
    "Quantity": 2
  },
  "ViewerCertificate": {
    "ACMCertificateArn": "${ACM_CERTIFICATE_ARN}",
    "SSLSupportMethod": "sni-only",
    "MinimumProtocolVersion": "TLSv1.2_2021"
  },
  "Aliases": {
    "Items": ["cdn.ivxholding.com"],
    "Quantity": 1
  },
  "HttpVersion": "http2and3",
  "PriceClass": "PriceClass_100",
  "Enabled": true
}
