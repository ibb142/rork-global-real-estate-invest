.git
.gitignore
.rork
# Exclude runtime logs EXCEPT the durable task-orchestrator ledger, which the
# canonical task store (GET /api/ivx/senior-developer/tasks) serves in production.
logs
!logs/audit/task-orchestrator
!logs/audit/task-orchestrator/**
node_modules
expo/node_modules
expo/.expo
expo/tmp
expo/dist-audit-ios
expo/dist-audit-ios-final
expo/dist-audit-ios-postfix
expo/dist-audit-web
expo/dist-audit-web-final
expo/dist-audit-web-postfix
.env
expo/.env
.env.bak
.env*.bak
expo/.env.bak
expo/.env*.bak
