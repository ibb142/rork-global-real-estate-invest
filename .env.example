# ============================================================
# IVX HOLDINGS - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ---- SYSTEM ----
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
ALLOWED_ORIGINS=https://ivxholding.com,https://www.ivxholding.com,https://app.ivxholding.com

# ---- AUTH (REQUIRED) ----
# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS

# ---- AWS (REQUIRED) ----
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=ivx-holdings-prod

# ---- PAYMENTS — STRIPE ----
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- PAYMENTS — PLAID ----
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production

# ---- PAYMENTS — PAYPAL ----
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=production

# ---- PAYMENTS — COINBASE COMMERCE ----
COINBASE_COMMERCE_API_KEY=

# ---- PAYMENTS — CIRCLE (USDC) ----
CIRCLE_API_KEY=

# ---- PAYMENTS — APPLE / GOOGLE PAY ----
APPLE_PAY_MERCHANT_ID=
GOOGLE_PAY_MERCHANT_ID=

# ---- COMMUNICATIONS — TWILIO ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=+1XXXXXXXXXX

# ---- COMMUNICATIONS — SENDGRID ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ivxholding.com
CEO_EMAIL=ceo@ivxholding.com

# ---- COMMUNICATIONS — MAILGUN (alternative to SendGrid) ----
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mail.ivxholding.com

# ---- KYC ----
ONFIDO_API_KEY=
JUMIO_API_KEY=

# ---- EXTERNAL APIS ----
GOOGLE_MAPS_API_KEY=
ATTOM_API_KEY=
ALPHA_VANTAGE_API_KEY=
OPENEXCHANGE_APP_ID=

# ---- STORAGE (optional — auto-detected from AWS keys) ----
# Options: s3 | r2 | local
STORAGE_PROVIDER=s3

# ---- CLOUDFLARE R2 (alternative to S3) ----
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# ---- MONITORING ----
SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX

# ---- EXPO PUBLIC (frontend — prefix required) ----
EXPO_PUBLIC_API_BASE_URL=https://api.ivxholding.com
